generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model auditlog {
  id         String   @id
  userId     String?
  clinicId   String?
  action     String
  targetType String
  targetId   String?
  details    String   @db.Text
  ipAddress  String
  timestamp  DateTime @default(now())
  clinic     clinic?  @relation(fields: [clinicId], references: [id], map: "AuditLog_clinicId_fkey")
  user       user?    @relation(fields: [userId], references: [id], map: "AuditLog_userId_fkey")

  @@index([clinicId], map: "AuditLog_clinicId_idx")
  @@index([userId], map: "AuditLog_userId_idx")
}

model certificate {
  id                String             @id
  certificateNumber String             @unique(map: "Certificate_certificateNumber_key")
  clinicId          String
  doctorId          String
  patientId         String
  type              certificate_type   @default(MEDICAL_CERTIFICATE)
  issueDate         DateTime           @default(now())
  startDate         DateTime
  endDate           DateTime
  durationDays      Int
  diagnosis         String             @db.Text
  remarks           String?            @db.Text
  status            certificate_status @default(ACTIVE)
  qrCodeUrl         String?            @db.Text
  qrUrl             String?            @db.Text
  qrPublicId        String?
  pdfUrl            String?            @db.Text
  pdfPublicId       String?
  verificationHash  String             @db.VarChar(64)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  deletedAt         DateTime?
  clinic            clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "Certificate_clinicId_fkey")
  doctor            doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade, map: "Certificate_doctorId_fkey")
  patient           patient            @relation(fields: [patientId], references: [id], onDelete: Cascade, map: "Certificate_patientId_fkey")
  certificatefile   certificatefile[]
  verificationlog   verificationlog[]

  @@index([certificateNumber], map: "Certificate_certificateNumber_idx")
  @@index([clinicId], map: "Certificate_clinicId_idx")
  @@index([deletedAt], map: "Certificate_deletedAt_idx")
  @@index([doctorId], map: "Certificate_doctorId_idx")
  @@index([patientId], map: "Certificate_patientId_idx")
  @@index([status], map: "Certificate_status_idx")
}

model certificatefile {
  id            String      @id
  certificateId String
  fileUrl       String      @db.Text
  filePublicId  String?
  fileType      String
  createdAt     DateTime    @default(now())
  certificate   certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade, map: "CertificateFile_certificateId_fkey")

  @@index([certificateId], map: "CertificateFile_certificateId_idx")
}

model clinic {
  id            String         @id
  name          String
  address       String         @db.Text
  contactNumber String
  email         String
  logoUrl       String?
  logoPublicId  String?
  themeConfig   String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?
  auditlog      auditlog[]
  certificate   certificate[]
  doctor        doctor[]
  patient       patient[]
  setting       setting[]
  staff         staff[]
  subscription  subscription[]
  user          user[]

  @@index([deletedAt], map: "Clinic_deletedAt_idx")
}

model doctor {
  id                String        @id
  userId            String        @unique(map: "Doctor_userId_key")
  clinicId          String
  licenseNumber     String        @unique(map: "Doctor_licenseNumber_key")
  specialization    String
  signatureUrl      String?
  signaturePublicId String?
  isSuspended       Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  deletedAt         DateTime?
  certificate       certificate[]
  clinic            clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "Doctor_clinicId_fkey")
  user              user          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Doctor_userId_fkey")

  @@index([clinicId], map: "Doctor_clinicId_idx")
  @@index([deletedAt], map: "Doctor_deletedAt_idx")
}

model notification {
  id        String    @id
  userId    String
  email     String
  subject   String
  body      String    @db.Text
  type      String
  sentAt    DateTime?
  status    String
  createdAt DateTime  @default(now())

  @@index([userId], map: "Notification_userId_idx")
}

model patient {
  id          String        @id
  clinicId    String
  fullName    String
  identifier  String
  dob         DateTime
  gender      String
  phone       String
  email       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  deletedAt   DateTime?
  certificate certificate[]
  clinic      clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "Patient_clinicId_fkey")

  @@unique([clinicId, identifier], map: "Patient_clinicId_identifier_key")
  @@index([clinicId], map: "Patient_clinicId_idx")
  @@index([deletedAt], map: "Patient_deletedAt_idx")
  @@index([identifier], map: "Patient_identifier_idx")
}

model session {
  id        String    @id
  userId    String
  token     String    @unique(map: "Session_token_key") @db.VarChar(512)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_idx")
}

model setting {
  id        String   @id
  clinicId  String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime
  clinic    clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "Setting_clinicId_fkey")

  @@unique([clinicId, key], map: "Setting_clinicId_key_key")
  @@index([clinicId], map: "Setting_clinicId_idx")
}

model staff {
  id          String    @id
  userId      String    @unique(map: "Staff_userId_key")
  clinicId    String
  position    String
  isSuspended Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  deletedAt   DateTime?
  clinic      clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "Staff_clinicId_fkey")
  user        user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Staff_userId_fkey")

  @@index([clinicId], map: "Staff_clinicId_idx")
  @@index([deletedAt], map: "Staff_deletedAt_idx")
}

model subscription {
  id        String   @id
  clinicId  String
  planName  String
  status    String
  price     Decimal  @db.Decimal(10, 2)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime
  clinic    clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "Subscription_clinicId_fkey")

  @@index([clinicId], map: "Subscription_clinicId_idx")
}

model user {
  id           String     @id
  email        String     @unique(map: "User_email_key")
  passwordHash String
  role         user_role  @default(PATIENT)
  firstName    String
  lastName     String
  phone        String?
  isSuspended  Boolean    @default(false)
  clinicId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  deletedAt    DateTime?
  auditlog     auditlog[]
  doctor       doctor?
  session      session[]
  staff        staff?
  clinic       clinic?    @relation(fields: [clinicId], references: [id], onDelete: Cascade, map: "User_clinicId_fkey")

  @@index([clinicId], map: "User_clinicId_idx")
  @@index([deletedAt], map: "User_deletedAt_idx")
  @@index([role], map: "User_role_idx")
}

model verificationlog {
  id            String       @id
  certificateId String?
  ipAddress     String
  device        String
  browser       String
  country       String
  result        String
  timestamp     DateTime     @default(now())
  certificate   certificate? @relation(fields: [certificateId], references: [id], map: "VerificationLog_certificateId_fkey")

  @@index([certificateId], map: "VerificationLog_certificateId_idx")
}

enum user_role {
  SUPER_ADMIN
  CLINIC_ADMIN
  DOCTOR
  STAFF
  PATIENT
}

enum certificate_type {
  MEDICAL_CERTIFICATE
  FITNESS_CERTIFICATE
  RETURN_TO_WORK_CERTIFICATE
  MEDICAL_REPORT
  VACCINATION_CERTIFICATE
  TRAVEL_HEALTH_CERTIFICATE
}

enum certificate_status {
  DRAFT
  ISSUED
  ACTIVE
  EXPIRED
  REVOKED
  CANCELLED
}
